[flake8]
max-line-length = 120
exclude =
    .git,
    __pycache__,
    .venv,
    news/migrations,
    */migrations,
    static,
    templates
extend-ignore =
    D100,
    D101,
    D102,
    D103,
    D104,
    D105,
    D106,
    D107,
    D200,
    D203,
    D205,
    D213,
    D400,
    D401,
    D402,
    D403,
    E221,
    E501,
    W503
